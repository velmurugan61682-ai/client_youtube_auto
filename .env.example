# =========================================================================
# Tech Vaseegraah Creator AI - Client Environment Template
# =========================================================================

# --- API & Web Socket Endpoints ---
# The URL pointing to the backend Node/Express API server.
VITE_API_URL=http://localhost:5000

# The URL pointing to the backend Socket.IO websocket server.
VITE_SOCKET_URL=http://localhost:5000

# --- Authentication Services ---
# Google OAuth Client ID for secure YouTube Channel connectivity.
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here

# --- Dev Server Configuration ---
# The port local Vite development server listens to.
PORT=5173
